[Unit]
Description=omp-mobile web UI
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__WORKDIR__
ExecStart=__BUN__ src/server.ts --host __HOST__ --port __PORT__
Restart=always
RestartSec=3
Environment=HOME=__HOME__
Environment=OMP_MOBILE_HOST=__HOST__
Environment=OMP_MOBILE_PORT=__PORT__

[Install]
WantedBy=multi-user.target
